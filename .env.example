# ===========================================
# PM3K - TikTok Sandbox Clone Platform
# Environment Variables Configuration
# ===========================================

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ===========================================
# MONGODB ATLAS CONFIGURATION
# ===========================================

# MongoDB Connection String
# Get this from MongoDB Atlas Dashboard
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/pm3k?retryWrites=true&w=majority

# ===========================================
# JWT CONFIGURATION
# ===========================================

# JWT Secret Key (Generate a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-generate-with-node-command

# JWT Expiry
JWT_EXPIRES_IN=7d

# ===========================================
# TIKTOK API CONFIGURATION
# ===========================================

# TikTok Environment (sandbox or production)
TIKTOK_ENV=sandbox

# TikTok App Client Key
# Get from TikTok Developer Portal
TIKTOK_CLIENT_KEY=your-tiktok-client-key

# TikTok App Client Secret
# Get from TikTok Developer Portal
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# OAuth Redirect URI
# This must match exactly what you configured in TikTok Developer Portal
# For local development: http://localhost:3000/oauth/callback
# For ngrok: https://your-ngrok-url.ngrok.io/oauth/callback
TIKTOK_REDIRECT_URI=http://localhost:3000/oauth/callback

# ===========================================
# UPLOAD CONFIGURATION
# ===========================================

# Maximum file size in bytes (50MB = 50 * 1024 * 1024)
MAX_FILE_SIZE=52428800

# Upload directory
UPLOAD_DIR=./uploads/videos

# Allowed video MIME types
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/webm
